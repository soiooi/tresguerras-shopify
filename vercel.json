{
  "version": 2,
  "builds": [
    {
      "src": "api/index.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/cotizar",
      "dest": "/api/index.js"
    },
    {
      "src": "/catalogos",
      "dest": "/api/index.js"
    },
    {
      "src": "/generar-guia",
      "dest": "/api/index.js"
    },
    {
      "src": "/rastrear",
      "dest": "/api/index.js"
    },
    {
      "src": "/",
      "dest": "/api/index.js"
    }
  ]
}